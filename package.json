{
  "name": "@newjersey/njwds",
  "version": "2.9.1",
  "description": "NJ Web Design Standards",
  "main": "index.js",
  "scripts": {
    "prepare": "npm run grove:build",
    "import-components": "cp -nr node_modules/uswds/src/components ./src/",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint",
    "test": "vitest run",
    "test:visual": "playwright test --project=visual",
    "test:accessibility": "playwright test --project=accessibility",
    "test:visual:update": "playwright test --project=visual --update-snapshots=all",
    "grove:dev": "vite build --config vite.config.grove.ts --watch",
    "grove:build": "vite build --config vite.config.grove.ts",
    "preview": "npx serve storybook-static",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newjersey/njwds.git"
  },
  "author": "dhcole",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/newjersey/njwds/issues"
  },
  "homepage": "https://github.com/newjersey/njwds#readme",
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "@newjersey/feedback-widget": "^0.7.1",
    "@uswds/uswds": "3.13.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.2",
    "@html-eslint/eslint-plugin": "^0.64.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/web-components-vite": "^10.2.8",
    "@types/node": "^22.19.6",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.1.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-wc": "^3.0.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "postcss": "^8.3.11",
    "postcss-csso": "^5.0.1",
    "prettier": "^3.7.4",
    "sass": "^1.97.3",
    "storybook": "^10.2.13",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "overrides": {
    "postcss": "^8.3.11",
    "got": "^12.1.0",
    "braces": "^3.0.3",
    "inquirer": {
      "lodash": "^4.17.19"
    }
  },
  "files": [
    "dist",
    "src",
    "package.json",
    ".browserslistrc",
    ".nvmrc"
  ]
}
